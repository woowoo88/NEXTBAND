<UserControl x:Class="NextBand.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:NextBand.Components"
             xmlns:services="clr-namespace:NextBand.Services">
    <Grid Background="White">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Width="390" HorizontalAlignment="Center" Margin="0,80">
                <TextBlock Text="NextBand" FontSize="34" FontWeight="Bold" Foreground="{StaticResource BlueBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Crie sua conta" Style="{StaticResource MutedText}" HorizontalAlignment="Center" Margin="0,8,0,38" />

                <TextBlock Text="Nome completo" Style="{StaticResource LabelText}" />
                <TextBox Text="{Binding RegisterFullName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20" />
                <TextBlock Text="Celular" Style="{StaticResource LabelText}" />
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <ComboBox ItemsSource="{Binding CountryDialCodes}"
                              SelectedItem="{Binding SelectedDialCode}"
                              Style="{StaticResource ModernComboBox}"
                              ItemContainerStyle="{StaticResource ModernComboBoxItem}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                                <Grid Width="172" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="30" Height="22" CornerRadius="5" Background="#ECFDF5" HorizontalAlignment="Left">
                                        <Image Source="{Binding IsoCode, Converter={StaticResource CountryFlagImageConverter}}"
                                               Width="24"
                                               Height="16"
                                               Stretch="Fill"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Name}"
                                               Foreground="{StaticResource InkBrush}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               Margin="4,0,6,0" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding DialCode}"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBox Grid.Column="2" Text="{Binding RegisterPhone, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <TextBlock Text="Email" Style="{StaticResource LabelText}" />
                <TextBox Text="{Binding RegisterEmail, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20" />
                <TextBlock Text="Senha" Style="{StaticResource LabelText}" />
                <Grid Margin="0,0,0,20">
                    <PasswordBox x:Name="RegisterPasswordBox" components:PasswordBoxAssistant.BoundPassword="{Binding RegisterPassword, Mode=TwoWay}" Padding="14,9,44,9">
                        <PasswordBox.Style>
                            <Style TargetType="{x:Type PasswordBox}" BasedOn="{StaticResource {x:Type PasswordBox}}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowRegisterPassword}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </PasswordBox.Style>
                    </PasswordBox>
                    <TextBox x:Name="RegisterPasswordTextBox" Text="{Binding RegisterPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="14,9,44,9">
                        <TextBox.Style>
                            <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowRegisterPassword}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <Border Width="24" Height="24" CornerRadius="12" Background="#DCFCE7" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="OK" Foreground="#16A34A" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Border.Style>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRegisterPasswordValid}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </Grid>
                <CheckBox Content="Mostrar senha" IsChecked="{Binding ShowRegisterPassword}" Checked="ShowRegisterPasswordChanged" Unchecked="ShowRegisterPasswordChanged" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,14" />
                <TextBlock Text="Confirmar senha" Style="{StaticResource LabelText}" />
                <Grid Margin="0,0,0,24">
                    <PasswordBox x:Name="RegisterConfirmPasswordBox" components:PasswordBoxAssistant.BoundPassword="{Binding RegisterConfirmPassword, Mode=TwoWay}" Padding="14,9,44,9">
                        <PasswordBox.Style>
                            <Style TargetType="{x:Type PasswordBox}" BasedOn="{StaticResource {x:Type PasswordBox}}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowRegisterConfirmPassword}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </PasswordBox.Style>
                    </PasswordBox>
                    <TextBox x:Name="RegisterConfirmPasswordTextBox" Text="{Binding RegisterConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="14,9,44,9">
                        <TextBox.Style>
                            <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowRegisterConfirmPassword}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <Border Width="24" Height="24" CornerRadius="12" Background="#DCFCE7" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="OK" Foreground="#16A34A" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Border.Style>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRegisterConfirmPasswordValid}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </Grid>
                <CheckBox Content="Mostrar confirmação" IsChecked="{Binding ShowRegisterConfirmPassword}" Checked="ShowRegisterConfirmPasswordChanged" Unchecked="ShowRegisterConfirmPasswordChanged" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,18" />

                <TextBlock Text="Nome de usuário" Style="{StaticResource LabelText}" />
                <TextBox Text="{Binding RegisterUserName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20" />

                <Button Content="Criar conta" Command="{Binding RegisterCommand}" Style="{StaticResource PrimaryButton}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                    <TextBlock Text="Ja tem uma conta? " Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                    <Button Content="Entrar" Command="{Binding NavigateCommand}" CommandParameter="{x:Static services:AppPage.Login}" Style="{StaticResource LinkButton}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

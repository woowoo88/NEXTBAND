<UserControl x:Class="NextBand.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:NextBand.Components"
             xmlns:services="clr-namespace:NextBand.Services">
    <Grid Background="White">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Width="390" HorizontalAlignment="Center" Margin="0,80">
                <TextBlock Text="NextBand" FontSize="34" FontWeight="Bold" Foreground="{StaticResource BlueBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Crie sua conta" Style="{StaticResource MutedText}" HorizontalAlignment="Center" Margin="0,8,0,38" />

                <TextBlock Text="Nome de usuario" Style="{StaticResource LabelText}" />
                <TextBox Text="{Binding RegisterUserName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20" />
                <TextBlock Text="Celular" Style="{StaticResource LabelText}" />
                <TextBox Text="{Binding RegisterPhone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20" />
                <TextBlock Text="Email" Style="{StaticResource LabelText}" />
                <TextBox Text="{Binding RegisterEmail, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20" />
                <TextBlock Text="Senha" Style="{StaticResource LabelText}" />
                <PasswordBox components:PasswordBoxAssistant.BoundPassword="{Binding RegisterPassword, Mode=TwoWay}" Margin="0,0,0,20" />
                <TextBlock Text="Confirmar senha" Style="{StaticResource LabelText}" />
                <PasswordBox components:PasswordBoxAssistant.BoundPassword="{Binding RegisterConfirmPassword, Mode=TwoWay}" Margin="0,0,0,24" />

                <Button Content="Criar conta" Command="{Binding RegisterCommand}" Style="{StaticResource PrimaryButton}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                    <TextBlock Text="Ja tem uma conta? " Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                    <Button Content="Entrar" Command="{Binding NavigateCommand}" CommandParameter="{x:Static services:AppPage.Login}" Style="{StaticResource LinkButton}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

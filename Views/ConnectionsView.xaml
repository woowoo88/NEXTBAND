<UserControl x:Class="NextBand.Views.ConnectionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="144" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Background="{StaticResource BrandGradient}" Padding="20,30,20,24">
            <StackPanel>
                <DockPanel Margin="0,0,0,18">
                    <Button Content="‹" Command="{Binding BackCommand}" Style="{StaticResource LinkButton}" Foreground="White" FontSize="28" DockPanel.Dock="Left" />
                    <TextBlock Text="Conexoes" Style="{StaticResource PageTitle}" Margin="10,0,0,0" />
                </DockPanel>
                <TextBox Text="{Binding ConnectionSearch, UpdateSourceTrigger=PropertyChanged}" Height="40" />
            </StackPanel>
        </Border>
        <ScrollViewer Grid.Row="1" Margin="16,18" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{Binding ConnectionCountText}" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,14" />
                <ItemsControl ItemsSource="{Binding FilteredConnections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource FlatCard}" Margin="0,0,0,12">
                                <DockPanel>
                                    <Button Content="⌄" Command="{Binding DataContext.ViewConnectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource LinkButton}" DockPanel.Dock="Right" />
                                    <TextBlock Text="{Binding ConnectedAgo}" Foreground="{StaticResource MutedBrush}" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,18,0" />
                                    <Border Width="48" Height="48" CornerRadius="24" Background="{StaticResource BrandGradient}" Margin="0,0,14,0">
                                        <TextBlock Text="P" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Margin="0,0,8,0" />
                                            <Border Background="{StaticResource BlueBrush}" CornerRadius="8" Padding="8,2">
                                                <TextBlock Text="Novo" Foreground="White" FontSize="11" FontWeight="Bold" />
                                                <Border.Style>
                                                    <Style TargetType="{x:Type Border}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsNew}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding UserName, StringFormat=@{0}}" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

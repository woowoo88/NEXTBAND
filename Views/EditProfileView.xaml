<UserControl x:Class="NextBand.Views.EditProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:NextBand.Components">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="140" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Background="{StaticResource BrandGradient}" Padding="20,30">
            <DockPanel>
                <Button Content="&lt;" Command="{Binding BackCommand}" Style="{StaticResource LinkButton}" Foreground="White" FontSize="22" Width="44" DockPanel.Dock="Left" />
                <TextBlock Text="Editar Perfil" Style="{StaticResource PageTitle}" Margin="10,0,0,0" />
            </DockPanel>
        </Border>
        <ScrollViewer Grid.RowSpan="2" Margin="16,84,16,0" VerticalScrollBarVisibility="Auto">
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <Border Width="96" Height="96" CornerRadius="48" Background="{StaticResource BrandGradient}" HorizontalAlignment="Center" Margin="0,8,0,8">
                        <TextBlock Text="P" Foreground="White" FontSize="42" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Toque para alterar a foto" HorizontalAlignment="Center" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,24" />

                    <TextBlock Text="Nome completo" Style="{StaticResource LabelText}" />
                    <TextBox Text="{Binding Data.User.FullName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,18" />
                    <TextBlock Text="Nome de usuário" Style="{StaticResource LabelText}" />
                    <TextBox Text="{Binding Data.User.UserName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,18" />
                    <TextBlock Text="Email" Style="{StaticResource LabelText}" />
                    <TextBox Text="{Binding Data.User.Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,18" />
                    <TextBlock Text="Nova senha" Style="{StaticResource LabelText}" />
                    <PasswordBox components:PasswordBoxAssistant.BoundPassword="{Binding Data.User.Password, Mode=TwoWay}" Margin="0,0,0,18" />
                    <TextBlock Text="Instagram" Style="{StaticResource LabelText}" />
                    <TextBox Text="{Binding Data.User.Instagram, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,18" />
                    <TextBlock Text="LinkedIn" Style="{StaticResource LabelText}" />
                    <TextBox Text="{Binding Data.User.LinkedIn, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,18" />
                    <TextBlock Text="Afiliação" Style="{StaticResource LabelText}" />
                    <TextBox Text="{Binding Data.User.Affiliation, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,18" />
                    <TextBlock Text="Idade" Style="{StaticResource LabelText}" />
                    <TextBox Text="{Binding Data.User.Age, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,18" />
                    <TextBlock Text="Biografia" Style="{StaticResource LabelText}" />
                    <TextBox Text="{Binding Data.User.Bio, UpdateSourceTrigger=PropertyChanged}" Height="92" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Margin="0,0,0,24" />
                    <Button Content="Salvar perfil" Command="{Binding SaveProfileCommand}" Style="{StaticResource PrimaryButton}" />
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>

<UserControl x:Class="NextBand.Views.EmergencyPublicView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="146" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Background="{StaticResource DangerBrush}" Padding="24,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="!" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,14,0" />
                <StackPanel>
                    <TextBlock Text="INFORMACOES DE EMERGENCIA" Foreground="White" FontWeight="Bold" />
                    <TextBlock Text="Em caso de emergência, ligue 192 (SAMU) ou 193." Foreground="White" />
                </StackPanel>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Background="{StaticResource BrandGradient}" Padding="0,30">
            <Grid>
                <Button Content="&lt; Voltar"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource LinkButton}"
                        Foreground="White"
                        FontWeight="Bold"
                        Width="98"
                        Height="34"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="24,-14,0,0" />
                <StackPanel Width="660" HorizontalAlignment="Center">
                    <TextBlock Text="CRIANÇA" Foreground="#DCFCE7" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Data.EmergencyProfile.ChildName}" Foreground="White" FontSize="30" FontWeight="Bold" />
                    <TextBlock Foreground="White" Margin="0,8,0,0">
                        <Run Text="Idade: " />
                        <Run Text="{Binding Data.EmergencyProfile.Age}" />
                        <Run Text="    Tipo sanguineo: " />
                        <Run Text="{Binding Data.EmergencyProfile.BloodType}" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Width="640" HorizontalAlignment="Center" Margin="0,24,0,40">
                <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                    <StackPanel>
                        <TextBlock Text="INFORMACOES PRINCIPAIS" FontWeight="Bold" FontSize="15" Margin="0,0,0,18" />
                        <TextBlock Text="RESPONSAVEIS" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                        <TextBlock Text="{Binding Data.EmergencyProfile.Guardians}" FontSize="16" FontWeight="SemiBold" Margin="0,2,0,16" />
                        <TextBlock Text="TELEFONE DE EMERGENCIA" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                        <Button Content="{Binding Data.EmergencyProfile.MainPhone, StringFormat=Ligar {0}}" Style="{StaticResource PrimaryButton}" Width="190" HorizontalAlignment="Left" Margin="0,6,0,16" />
                        <TextBlock Text="ENDERECO" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                        <TextBlock Text="{Binding Data.EmergencyProfile.Address}" FontSize="16" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource FlatCard}">
                    <StackPanel>
                        <TextBlock Text="OUTRAS INFORMACOES" FontWeight="Bold" FontSize="15" Margin="0,0,0,16" />
                        <StackPanel>
                            <StackPanel Margin="0,0,0,18">
                                <TextBlock Text="ALERGIAS" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                <TextBlock Text="{Binding Data.EmergencyProfile.Allergies}" FontSize="15" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,18">
                                <TextBlock Text="CONDICOES MEDICAS" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                <TextBlock Text="{Binding Data.EmergencyProfile.MedicalConditions}" FontSize="15" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,18">
                                <TextBlock Text="DEFICIENCIAS" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                <TextBlock Text="{Binding Data.EmergencyProfile.Disabilities}" FontSize="15" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,18">
                                <TextBlock Text="NECESSIDADES ESPECIAIS" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                <TextBlock Text="{Binding Data.EmergencyProfile.SpecialNeeds}" FontSize="15" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,18">
                                <TextBlock Text="MEDICAMENTOS" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                <TextBlock Text="{Binding EmergencyPublicMedication}" FontSize="15" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,18">
                                <TextBlock Text="INSTRUCOES PARA EMERGENCIA" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                <TextBlock Text="{Binding Data.EmergencyProfile.EmergencyInstructions}" FontSize="15" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="CONTATOS ADICIONAIS" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,4,0,8" />
                        <ItemsControl ItemsSource="{Binding Data.EmergencyProfile.ExtraContacts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,0,0,8">
                                        <Run Text="{Binding Name}" FontWeight="SemiBold" />
                                        <Run Text=" - " />
                                        <Run Text="{Binding Phone}" />
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

<UserControl x:Class="NextBand.Views.MyBandView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:NextBand.Services">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Background="{StaticResource BrandGradient}" Padding="20,0">
            <DockPanel>
                <Button Content="&lt;" Command="{Binding BackCommand}" Style="{StaticResource LinkButton}" Foreground="White" FontSize="22" Width="44" DockPanel.Dock="Left" />
                <TextBlock Text="My Band" Style="{StaticResource PageTitle}" Margin="10,0,0,0" />
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="16" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource FlatCard}" Margin="0,0,0,16">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="{Binding Data.Band.DeviceName}" FontWeight="SemiBold" FontSize="16" />
                            <TextBlock Text="{Binding BandStatusText}" Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="Bluetooth" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,14,0" />
                            <Ellipse Width="12" Height="12" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Button Content="Conectar com a Band" Command="{Binding ConnectBandCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,0,16" />

                <Border Style="{StaticResource FlatCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="URL personalizada" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock Text="Crie a página acessível via NFC ou link com informações essenciais da criança." Style="{StaticResource MutedText}" Margin="0,0,0,14" />
                        <Button Command="{Binding NavigateCommand}" CommandParameter="{x:Static services:AppPage.CustomUrl}" Style="{StaticResource PrimaryButton}">
                            <TextBlock Text="URL personalizada    Configurar página de emergência    &gt;" />
                        </Button>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource FlatCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="LINK RAPIDO" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,10" />
                        <ComboBox SelectedValue="{Binding Data.Band.QuickLinkType}" SelectedValuePath="Content" Height="40" Margin="0,0,0,12">
                            <ComboBoxItem Content="Instagram" />
                            <ComboBoxItem Content="LinkedIn" />
                            <ComboBoxItem Content="URL" />
                        </ComboBox>
                        <TextBox Text="{Binding Data.Band.QuickLink, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" />
                        <Button Content="Enviar para a pulseira" Command="{Binding SendBandCommand}" Style="{StaticResource PrimaryButton}" />
                    </StackPanel>
                </Border>

                <TextBlock Text="CONFIGURACOES" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,8,0,12" />
                <Border Style="{StaticResource FlatCard}" Margin="0,0,0,16">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Modo criança" FontWeight="SemiBold" />
                            <TextBlock Text="Restringe funcionalidades e oculta dados sensíveis para uso seguro por crianças." Style="{StaticResource MutedText}" />
                        </StackPanel>
                        <CheckBox IsChecked="{Binding Data.Band.ChildMode}" Style="{StaticResource ToggleCheckBox}" HorizontalAlignment="Right" />
                    </DockPanel>
                </Border>

                <Border Style="{StaticResource FlatCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Permissões" FontWeight="SemiBold" Margin="0,0,0,14" />
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="Notificações" DockPanel.Dock="Left" />
                            <CheckBox IsChecked="{Binding Data.Band.NotificationsEnabled}" Style="{StaticResource ToggleCheckBox}" HorizontalAlignment="Right" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="Localização" DockPanel.Dock="Left" />
                            <CheckBox IsChecked="{Binding Data.Band.LocationEnabled}" Style="{StaticResource ToggleCheckBox}" HorizontalAlignment="Right" />
                        </DockPanel>
                    </StackPanel>
                </Border>
                <Button Content="Sair da conta" Command="{Binding LogoutCommand}" Style="{StaticResource DangerButton}" Margin="0,0,0,30" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

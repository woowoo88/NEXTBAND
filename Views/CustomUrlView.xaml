<UserControl x:Class="NextBand.Views.CustomUrlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="98" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Background="{StaticResource BrandGradient}" Padding="20,0">
            <DockPanel>
                <Button Content="&lt;" Command="{Binding BackCommand}" Style="{StaticResource LinkButton}" Foreground="White" FontSize="22" Width="44" DockPanel.Dock="Left" />
                <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="URL personalizada" Style="{StaticResource PageTitle}" />
                    <TextBlock Text="Página acessível via NFC ou link" Foreground="#E9E7FF" />
                </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="16" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource FlatCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Privacidade" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock Text="Os dados ficam armazenados neste dispositivo. Compartilhe o link apenas com pessoas de confiança ou via NFC da pulseira em situações de emergência." Foreground="{StaticResource MutedBrush}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource FlatCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Identificacao" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,16" />
                        <TextBlock Text="Nome da criança *" Style="{StaticResource LabelText}" />
                        <TextBox Text="{Binding Data.EmergencyProfile.ChildName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,18" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Idade" Style="{StaticResource LabelText}" />
                                <TextBox Text="{Binding Data.EmergencyProfile.Age, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Tipo sanguineo" Style="{StaticResource LabelText}" />
                                <ComboBox SelectedValue="{Binding Data.EmergencyProfile.BloodType, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Content"
                                          Height="42"
                                          VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="A+" />
                                    <ComboBoxItem Content="A-" />
                                    <ComboBoxItem Content="B+" />
                                    <ComboBoxItem Content="B-" />
                                    <ComboBoxItem Content="AB+" />
                                    <ComboBoxItem Content="AB-" />
                                    <ComboBoxItem Content="O+" />
                                    <ComboBoxItem Content="O-" />
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource FlatCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Responsaveis e contato" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,16" />
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Nome dos responsáveis" Style="{StaticResource LabelText}" DockPanel.Dock="Left" />
                            <Button Content="+ Responsavel"
                                    Command="{Binding AddGuardianCommand}"
                                    Style="{StaticResource LinkButton}"
                                    HorizontalAlignment="Right" />
                        </DockPanel>
                        <TextBox Text="{Binding Data.EmergencyProfile.Guardians, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,18" />
                        <TextBlock Text="Telefone principal de emergência" Style="{StaticResource LabelText}" />
                        <TextBox Text="{Binding Data.EmergencyProfile.MainPhone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,18" />
                        <TextBlock Text="Endereço" Style="{StaticResource LabelText}" />
                        <TextBox Text="{Binding Data.EmergencyProfile.Address, UpdateSourceTrigger=PropertyChanged}" Height="62" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource FlatCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Saúde" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,16" />
                        <TextBlock Text="Alergias" Style="{StaticResource LabelText}" />
                        <TextBox Text="{Binding Data.EmergencyProfile.Allergies, UpdateSourceTrigger=PropertyChanged}" Height="62" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Margin="0,0,0,18" />
                        <TextBlock Text="Condições médicas" Style="{StaticResource LabelText}" />
                        <TextBox Text="{Binding Data.EmergencyProfile.MedicalConditions, UpdateSourceTrigger=PropertyChanged}" Height="62" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Margin="0,0,0,18" />
                        <TextBlock Text="Deficiências" Style="{StaticResource LabelText}" />
                        <TextBox Text="{Binding Data.EmergencyProfile.Disabilities, UpdateSourceTrigger=PropertyChanged}" Height="62" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Margin="0,0,0,18" />
                        <TextBlock Text="Necessidades especiais" Style="{StaticResource LabelText}" />
                        <TextBox Text="{Binding Data.EmergencyProfile.SpecialNeeds, UpdateSourceTrigger=PropertyChanged}" Height="62" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Margin="0,0,0,18" />
                        <TextBlock Text="Medicamentos em uso" Style="{StaticResource LabelText}" />
                        <TextBox Text="{Binding Data.EmergencyProfile.Medications, UpdateSourceTrigger=PropertyChanged}" Height="62" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Margin="0,0,0,18" />
                        <TextBlock Text="Instruções para emergência" Style="{StaticResource LabelText}" />
                        <TextBox Text="{Binding Data.EmergencyProfile.EmergencyInstructions, UpdateSourceTrigger=PropertyChanged}" Height="82" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource FlatCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Contatos de emergência adicionais" FontWeight="SemiBold" FontSize="16" />
                        <TextBlock Text="Adicione contatos extras de familiares ou pessoas de confiança." Style="{StaticResource MutedText}" Margin="0,8,0,14" />
                        <ItemsControl ItemsSource="{Binding Data.EmergencyProfile.ExtraContacts}" Margin="0,0,0,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource SoftBrush}" CornerRadius="6" Padding="14" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="10" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Nome" Style="{StaticResource MutedText}" />
                                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Relação" Style="{StaticResource MutedText}" />
                                                <TextBox Text="{Binding Relation, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="2">
                                                <TextBlock Text="Telefone" Style="{StaticResource MutedText}" />
                                                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Grid.Column="2">
                                                <TextBlock Text="Observação" Style="{StaticResource MutedText}" />
                                                <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ Adicionar contato" Command="{Binding AddEmergencyContactCommand}" Style="{StaticResource SecondaryButton}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource FlatCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Outras informações" FontWeight="SemiBold" FontSize="16" />
                        <TextBlock Text="Adicione qualquer informação adicional relevante, ex: plano de saúde, escola, pediatra." Style="{StaticResource MutedText}" Margin="0,8,0,14" />
                        <ItemsControl ItemsSource="{Binding Data.EmergencyProfile.CustomInfos}" Margin="0,0,0,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource SoftBrush}" CornerRadius="6" Padding="14" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Título" Style="{StaticResource MutedText}" />
                                                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Descricao" Style="{StaticResource MutedText}" />
                                                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ Adicionar informação" Command="{Binding AddCustomInfoCommand}" Style="{StaticResource SecondaryButton}" />
                    </StackPanel>
                </Border>

                <Grid Margin="0,4,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Button Content="Visualizar" Command="{Binding PreviewEmergencyCommand}" Style="{StaticResource SecondaryButton}" />
                    <Button Grid.Column="2" Content="Salvar" Command="{Binding SaveEmergencyCommand}" Style="{StaticResource PrimaryButton}" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

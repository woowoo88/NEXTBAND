<Window x:Class="NextBand.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NextBand.Views"
        Title="NextBand"
        MinWidth="980"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Grid Background="White">
        <views:LoginView Visibility="{Binding IsLoginVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
        <views:RegisterView Visibility="{Binding IsRegisterVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
        <views:DashboardView Visibility="{Binding IsDashboardVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
        <views:ProfileView Visibility="{Binding IsProfileVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
        <views:EditProfileView Visibility="{Binding IsEditProfileVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
        <views:ConnectionsView Visibility="{Binding IsConnectionsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
        <views:MyBandView Visibility="{Binding IsMyBandVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
        <views:CustomUrlView Visibility="{Binding IsCustomUrlVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
        <views:EmergencyPublicView Visibility="{Binding IsEmergencyPublicVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

        <Border HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="24"
                Padding="18,10"
                CornerRadius="8"
                Background="#F9FAFB"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
            <Border.Style>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusMessage}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>
    </Grid>
</Window>

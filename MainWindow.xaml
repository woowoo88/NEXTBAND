<Window x:Class="NextBand.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NextBand.Views"
        Title="NextBand"
        MinWidth="980"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Grid Background="White">
        <views:LoginView Tag="{Binding IsLoginVisible}" Visibility="{Binding IsLoginVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
        <views:RegisterView Tag="{Binding IsRegisterVisible}" Visibility="{Binding IsRegisterVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
        <views:DashboardView Tag="{Binding IsDashboardVisible}" Visibility="{Binding IsDashboardVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
        <views:ProfileView Tag="{Binding IsProfileVisible}" Visibility="{Binding IsProfileVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
        <views:EditProfileView Tag="{Binding IsEditProfileVisible}" Visibility="{Binding IsEditProfileVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
        <views:ConnectionsView Tag="{Binding IsConnectionsVisible}" Visibility="{Binding IsConnectionsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
        <views:MyBandView Tag="{Binding IsMyBandVisible}" Visibility="{Binding IsMyBandVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
        <views:CustomUrlView Tag="{Binding IsCustomUrlVisible}" Visibility="{Binding IsCustomUrlVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
        <views:EmergencyPublicView Tag="{Binding IsEmergencyPublicVisible}" Visibility="{Binding IsEmergencyPublicVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

        <Border HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="24"
                Padding="14,10"
                CornerRadius="8"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <Border Width="20" Height="20" CornerRadius="10" Background="#FCA5A5" Margin="0,0,10,0">
                    <TextBlock Text="!" Foreground="#991B1B" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Border.Style>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <TextBlock Text="{Binding StatusMessage}" FontWeight="SemiBold" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                    <Setter Property="Foreground" Value="#991B1B" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
            <Border.Style>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Setter Property="Background" Value="#F9FAFB" />
                    <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsStatusVisible}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                            <Setter Property="Background" Value="#FEF2F2" />
                            <Setter Property="BorderBrush" Value="#FECACA" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>
    </Grid>
</Window>
